# ============================================================
# ENVIRONMENT TEMPLATE
# Copy to .env for local development (docker compose up)
# For Azure, set these as App Service Configuration settings.
# NEVER commit real secrets to GitHub.
# ============================================================

# Django
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Engine: postgresql (local) | mssql (Azure)
DB_ENGINE=postgresql

# PostgreSQL (local Docker Compose)
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=your-local-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Azure SQL Database (production)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# Azure Blob Storage (Unit 5+)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=
AZURE_STORAGE_CONNECTION_STRING=

# Azure Key Vault (Unit 6+)
AZURE_KEY_VAULT_NAME=
